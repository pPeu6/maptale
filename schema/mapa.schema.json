{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://maptale.local/schema/mapa.schema.json",
  "title": "MapaAmbiente",
  "description": "Formato do mapa do jogo Maptale (Raspberry Pi / Pygame). Coordenadas x,y em metros no plano top-down.",
  "type": "object",
  "required": [
    "nome_ambiente",
    "escala_metros_por_tile",
    "paredes",
    "portas",
    "janelas",
    "objetos"
  ],
  "additionalProperties": false,
  "properties": {
    "nome_ambiente": {
      "type": "string",
      "minLength": 1,
      "description": "Identificador do ambiente / nome do arquivo JSON."
    },
    "escala_metros_por_tile": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Metros do mundo real por tile da grade."
    },
    "paredes": {
      "type": "array",
      "items": { "$ref": "#/definitions/segmento" }
    },
    "portas": {
      "type": "array",
      "items": { "$ref": "#/definitions/aberturaComLargura" }
    },
    "janelas": {
      "type": "array",
      "items": { "$ref": "#/definitions/aberturaComLargura" }
    },
    "objetos": {
      "type": "array",
      "items": { "$ref": "#/definitions/objeto" }
    },
    "pisos": {
      "type": "array",
      "description": "Regioes de piso especial (ex.: banheiro), desenhadas sobre o piso padrao.",
      "items": { "$ref": "#/definitions/piso" }
    }
  },
  "definitions": {
    "ponto2d": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "segmento": {
      "type": "object",
      "required": ["inicio", "fim"],
      "additionalProperties": false,
      "properties": {
        "inicio": { "$ref": "#/definitions/ponto2d" },
        "fim": { "$ref": "#/definitions/ponto2d" }
      }
    },
    "aberturaComLargura": {
      "type": "object",
      "required": ["posicao", "largura"],
      "additionalProperties": false,
      "properties": {
        "posicao": { "$ref": "#/definitions/ponto2d" },
        "largura": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "objeto": {
      "type": "object",
      "required": ["tipo", "posicao"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "minLength": 1 },
        "posicao": {
          "$ref": "#/definitions/ponto2d",
          "description": "Canto superior-esquerdo do objeto em metros."
        },
        "tamanho": {
          "type": "array",
          "items": { "type": "number", "exclusiveMinimum": 0 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Largura e altura em metros. Default: 1 tile (escala)."
        }
      }
    },
    "piso": {
      "type": "object",
      "required": ["tipo", "posicao", "tamanho"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "minLength": 1 },
        "posicao": {
          "$ref": "#/definitions/ponto2d",
          "description": "Canto superior-esquerdo da regiao em metros."
        },
        "tamanho": {
          "type": "array",
          "items": { "type": "number", "exclusiveMinimum": 0 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Largura e altura em metros."
        }
      }
    }
  },
  "examples": [
    {
      "nome_ambiente": "quarto",
      "escala_metros_por_tile": 0.5,
      "paredes": [
        { "inicio": [0.0, 0.0], "fim": [6.0, 0.0] },
        { "inicio": [6.0, 0.0], "fim": [6.0, 4.0] }
      ],
      "portas": [
        { "posicao": [0.0, 1.0], "largura": 0.9 }
      ],
      "janelas": [
        { "posicao": [3.0, 4.0], "largura": 1.2 }
      ],
      "objetos": [
        { "tipo": "cama", "posicao": [2.0, 1.0], "tamanho": [1.5, 2.0] }
      ]
    }
  ]
}
